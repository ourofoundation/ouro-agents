{
  "agent": {
    "name": "feynman",
    "model": "xiaomi/mimo-v2-omni",
    "workspace": "./workspace"
  },
  "prompt_caching": {
    "enabled": true,
    "ttl": "5m"
  },
  "heartbeat": {
    "enabled": true,
    "every": "30m",
    "model": "xiaomi/mimo-v2-omni",
    "active_hours": {
      "start": "08:00",
      "end": "22:00",
      "timezone": "America/Chicago"
    },
    "proactive": {
      "enabled": true,
      "servers": ["ouro", "search"]
    }
  },
  "mcp_servers": [
    {
      "name": "ouro",
      "transport": "stdio",
      "command": "/Users/mmoderwell/.pyenv/versions/ouro/bin/python",
      "args": ["-m", "ouro_mcp.server"],
      "env": {
        "OURO_API_KEY": "${OURO_API_KEY}",
        "OURO_BASE_URL": "${OURO_BASE_URL}"
      }
    },
    {
      "name": "search",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "tavily-mcp@0.1.4"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    }
  ],
  "memory": {
    "provider": "mem0",
    "path": "./workspace/memory",
    "extraction_model": "google/gemini-2.5-flash",
    "embedder": "text-embedding-3-small",
    "search_limit": 10,
    "retrieval_queries": 3,
    "max_retrieval_tokens": 800,
    "consolidation_enabled": true,
    "memory_md_max_tokens": 1500,
    "mid_session_reflection_interval": 5,
    "decay_after_days": 30,
    "graph": {
      "enabled": false
    }
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
